MONGODB_URI=mongodb+srv://...

# Base URL for public form links (e.g. https://yoursite.com without trailing slash). Full form URL: {formBaseUrl}/forms/{slug}
PUBLIC_FORM_BASE_URL=https://yoursite.com
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
NUXT_SESSION_PASSWORD=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=Form-Generator-Logos

# Google Picker / Sheets integration
GOOGLE_API_KEY=
GOOGLE_PICKER_APP_ID=

# Google Service Account for server-side Sheets writes. Use ONE of these options:
# Option A: Path to the JSON key file (recommended - supports multiline)
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./service-account-key.json
# Option B: Minified JSON on a single line
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
